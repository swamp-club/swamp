{
  "name": "@swamp/cli",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "exports": "./main.ts",
  "tasks": {
    "dev": "deno run --allow-read --allow-write --allow-env --allow-run --allow-sys main.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-run --allow-net",
    "check": "deno check main.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "compile": "deno run -A scripts/compile.ts",
    "license-headers": "deno run --allow-read --allow-write scripts/add_license_headers.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/fmt": "jsr:@std/fmt@1",
    "@std/cli": "jsr:@std/cli@1",
    "@std/fs": "jsr:@std/fs@1",
    "@std/path": "jsr:@std/path@1",
    "@std/yaml": "jsr:@std/yaml@1",
    "zod": "npm:zod@4",
    "@cliffy/command": "jsr:@cliffy/command@1.0.0-rc.8",
    "@logtape/logtape": "jsr:@logtape/logtape@2",
    "@logtape/pretty": "jsr:@logtape/pretty@2",
    "fzf": "npm:fzf@0.5.2",
    "ink": "npm:ink@5",
    "ink-testing-library": "npm:ink-testing-library@4",
    "react": "npm:react@18",
    "react/jsx-runtime": "npm:react@18/jsx-runtime",
    "@types/react": "npm:@types/react@18",
    "@aws-sdk/client-cloudcontrol": "npm:@aws-sdk/client-cloudcontrol@3",
    "@aws-sdk/client-secrets-manager": "npm:@aws-sdk/client-secrets-manager@3",
    "cel-js": "npm:@marcbachmann/cel-js@7.3.1",
    "fast-json-patch": "npm:fast-json-patch@3"
  },
  "compilerOptions": {
    "jsx": "react",
    "strict": true
  },
  "exclude": [
    "design/",
    "scripts/",
    ".github/",
    ".agents/",
    "workflows/",
    ".vault-test-vault/"
  ]
}
