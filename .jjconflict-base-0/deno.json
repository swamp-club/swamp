{
  "name": "@swamp/cli",
  "version": "0.1.0",
  "exports": "./main.ts",
  "tasks": {
    "dev": "deno run --allow-read --allow-write --allow-env main.ts",
    "test": "deno test --allow-read --allow-write --allow-env --allow-run",
    "check": "deno check main.ts",
    "lint": "deno lint",
    "fmt": "deno fmt",
    "compile": "deno compile --allow-read --allow-write --allow-env --output swamp main.ts"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/fs": "jsr:@std/fs@1",
    "@std/path": "jsr:@std/path@1",
    "@std/yaml": "jsr:@std/yaml@1",
    "zod": "npm:zod@4",
    "@cliffy/command": "jsr:@cliffy/command@1.0.0-rc.8",
    "@logtape/logtape": "jsr:@logtape/logtape@0.8",
    "fzf": "npm:fzf@0.5.2",
    "ink": "npm:ink@5",
    "ink-testing-library": "npm:ink-testing-library@4",
    "react": "npm:react@18",
    "react/jsx-runtime": "npm:react@18/jsx-runtime",
    "@types/react": "npm:@types/react@18"
  },
  "compilerOptions": {
    "jsx": "react",
    "strict": true
  }
}
